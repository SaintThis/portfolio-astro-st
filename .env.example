# Copy to `.env` and fill in. All PUBLIC_ vars are exposed to the client.

# Public site URL (also set `site` in astro.config.mjs)
PUBLIC_SITE_URL="https://saintrabor.dev"

# --- Future API integration (see src/lib/api) ---
# Base URL of your backend. When empty, the app falls back to local example data.
PUBLIC_API_BASE_URL=""

# Server-only secret (never prefixed with PUBLIC_) — e.g. for the contact form handler.
CONTACT_FORM_ENDPOINT=""
API_SECRET_KEY=""

# --- Analytics (both optional, independent — see src/components/seo/Analytics.astro) ---
# GA4 Measurement ID from analytics.google.com (looks like "G-XXXXXXXXXX").
PUBLIC_GA_MEASUREMENT_ID=""
# Cloudflare Web Analytics beacon token from the Cloudflare dashboard
# (Analytics & Logs → Web Analytics → Add site). No cookies, no consent banner needed.
PUBLIC_CF_BEACON_TOKEN=""
