{
  "name": "portfolio-astro-st",
  "type": "module",
  "version": "0.1.0",
  "description": "Cyberpunk / coder-themed personal portfolio built with Astro — fast, SEO-friendly, API-ready.",
  "author": "Saint Rabor <saintstraborrr@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "npm run build && wrangler dev",
    "astro": "astro",
    "check": "astro check",
    "format": "prettier --write \"src/**/*.{astro,ts,tsx,css,md,json}\"",
    "lint": "eslint . --ext .js,.ts,.astro,.tsx",
    "typecheck": "tsc --noEmit",
    "generate-types": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "db:migrate:prod": "dotenv -e .env.production -- drizzle-kit migrate",
    "db:seed:prod": "dotenv -e .env.production -- tsx scripts/seed.ts",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.2",
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/react": "^6.0.1",
    "@astrojs/rss": "^4.0.19",
    "@base-ui/react": "^1.6.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@neondatabase/serverless": "^1.1.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/rapier": "^2.2.0",
    "@shikijs/core": "^4.3.1",
    "@shikijs/engine-javascript": "^4.3.1",
    "@shikijs/langs": "^4.3.1",
    "@shikijs/themes": "^4.3.1",
    "astro": "^7.0.7",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "gsap": "^3.12.7",
    "meshline": "^3.3.1",
    "motion": "^12.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-smartypants": "^3.0.2",
    "shiki": "^4.3.1",
    "tailwind-merge": "^3.0.1",
    "three": "^0.185.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.5.0",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "^5.7.3",
    "wrangler": "4.110.0"
  }
}
