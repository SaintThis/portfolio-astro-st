---
/**
 * v2 nav — flat black bar, thick bottom rule, mono uppercase links.
 * "Home" points to /v2 (this alt site); every other link routes back to
 * v1's actual pages, since only the v2 home page exists so far (Phase 1).
 */
import { NAV_LINKS, SITE } from '@/config';

const pathname = Astro.url.pathname;
const links = NAV_LINKS.map((l) => ({ ...l, href: l.href === '/' ? '/v2' : l.href }));
---

<header class="border-b-4 border-v2-cream bg-v2-black">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5">
    <a href="/v2" class="font-display text-lg uppercase tracking-tight text-v2-cream">
      {SITE.name.split(' ')[0]}<span class="text-v2-red">.</span>
    </a>

    <nav aria-label="Primary" class="hidden items-center gap-1 sm:flex">
      {
        links.map((link) => {
          const active = pathname === link.href;
          return (
            <a
              href={link.href}
              aria-current={active ? 'page' : undefined}
              class:list={[
                'px-3 py-1.5 font-mono text-xs uppercase tracking-[0.15em] transition-colors',
                active ? 'bg-v2-red text-v2-black' : 'text-v2-cream hover:text-v2-yellow',
              ]}
            >
              {link.label}
            </a>
          );
        })
      }
    </nav>
  </div>
</header>
