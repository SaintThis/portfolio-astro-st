---
/**
 * ChannelHeader — broadcast-ident style section header: a "CH. 01" index,
 * an optional blinking "ON AIR" live indicator, and the section title in
 * the v2 display face.
 */
interface Props {
  index: string; // e.g. "01"
  title: string;
  live?: boolean;
}

const { index, title, live = false } = Astro.props;
---

<header class="mb-8 flex flex-col gap-2">
  <div class="flex items-center gap-3 font-mono text-xs tracking-[0.2em] text-v2-yellow uppercase">
    <span>CH.{index}</span>
    {
      live && (
        <span class="flex items-center gap-1.5 text-v2-red">
          <i class="broadcast-live-dot inline-block h-1.5 w-1.5 rounded-full bg-v2-red" />
          On Air
        </span>
      )
    }
  </div>
  <h2 class="font-display text-3xl uppercase leading-none text-v2-cream sm:text-5xl">
    {title}
  </h2>
</header>
