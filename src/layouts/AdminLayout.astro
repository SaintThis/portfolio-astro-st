---
/**
 * AdminLayout — chrome for the /admin editor pages. Always `noindex`, and holds
 * the shared form styles so PostForm/ProjectForm stay markup-only. Access is
 * enforced by middleware + Cloudflare Access, not here.
 */
import BaseLayout from '@layouts/BaseLayout.astro';

interface Props {
  title: string;
}
const { title } = Astro.props;
export const prerender = false;
---

<BaseLayout title={`Admin · ${title}`} noindex>
  <div class="py-14">
    <header class="mb-8 flex items-center justify-between gap-4">
      <div>
        <p class="kicker text-fg-faint"><span class="text-accent-2">//</span> Admin</p>
        <h1 class="mt-1 text-2xl font-extrabold">{title}</h1>
      </div>
      <a href="/admin" class="font-mono text-sm text-fg-muted hover:text-accent" data-cursor="hover"
        >dashboard</a
      >
    </header>
    <slot />
  </div>
</BaseLayout>

<style is:global>
  .admin-form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    max-width: 46rem;
  }
  .af-row {
    display: grid;
    gap: 1.1rem;
  }
  @media (min-width: 640px) {
    .af-row {
      grid-template-columns: 1fr 1fr;
    }
  }
  .af-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .af-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-fg-muted);
  }
  .af-hint {
    color: var(--color-fg-faint);
    font-style: normal;
    text-transform: none;
    letter-spacing: 0;
  }
  .af-input {
    width: 100%;
    padding: 0.6rem 0.75rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-box);
    color: var(--color-fg);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    transition: border-color 0.2s var(--ease-out-expo);
  }
  .af-input:focus {
    outline: none;
    border-color: var(--color-accent);
  }
  .af-textarea {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.6;
    resize: vertical;
  }
  .af-checks {
    display: flex;
    gap: 1.5rem;
  }
  .af-check {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-fg-muted);
  }
  .af-actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin-top: 0.5rem;
  }
  .af-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 1.1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-box);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-fg-muted);
    background: transparent;
    cursor: pointer;
    transition: all 0.2s var(--ease-out-expo);
  }
  .af-btn:hover {
    color: var(--color-fg);
    border-color: var(--color-accent);
  }
  .af-btn--primary {
    background: var(--color-accent);
    color: var(--color-accent-contrast);
    border-color: var(--color-accent);
  }
  .af-btn--primary:hover {
    color: var(--color-accent-contrast);
    box-shadow: var(--glow) color-mix(in srgb, var(--color-accent) 45%, transparent);
  }
  .af-btn--danger {
    color: var(--color-danger);
    border-color: color-mix(in srgb, var(--color-danger) 40%, var(--color-border));
  }
  .af-btn--danger:hover {
    border-color: var(--color-danger);
    color: var(--color-danger);
  }
  /* Admin dashboard list */
  .admin-list {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-box);
    overflow: hidden;
  }
  .admin-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 1rem;
    border-top: 1px solid var(--color-border);
  }
  .admin-row:first-child {
    border-top: none;
  }
  .admin-row a.admin-row__title {
    font-weight: 600;
    color: var(--color-fg);
  }
  .admin-row a.admin-row__title:hover {
    color: var(--color-accent);
  }
</style>
