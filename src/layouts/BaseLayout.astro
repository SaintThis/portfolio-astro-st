---
/**
 * BaseLayout — the app shell every page renders inside.
 *
 * Responsibilities:
 *  - <head>: SEO, fonts, favicon
 *  - No-flash theme application (before first paint)
 *  - Astro View Transitions (<ClientRouter />) → smooth routing + boot loader
 *  - Global islands: custom Cursor, IntroLoader, ScrollReveal engine
 *  - Header / <main> / Footer chrome
 */
import '@styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { SITE, DEFAULT_THEME, FEATURES } from '@/config';
import SEO from '@components/seo/SEO.astro';
import Analytics from '@components/seo/Analytics.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import IntroLoader from '@components/layout/IntroLoader.astro';
import ScrollReveal from '@components/layout/ScrollReveal.astro';
import Cursor from '@components/react/Cursor.tsx';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
  noindex?: boolean;
  /** Set false on ultra-minimal pages (e.g. 404) to drop the grid backdrop. */
  backdrop?: boolean;
}

const { backdrop = true, ...seo } = Astro.props;
---

<!doctype html>
<html lang="en" class="no-js" data-theme={DEFAULT_THEME}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content={SITE.themeColor} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />

    <!-- Fonts: preconnect + swap. Swap to @fontsource for full self-hosting (see DESIGN.md). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <SEO {...seo} />
    <Analytics />

    <!-- No-flash theme: apply persisted theme BEFORE paint. `is:inline` keeps it
         un-bundled so it runs synchronously in <head>. -->
    <script is:inline>
      (() => {
        const applyTheme = () => {
          try {
            const stored = JSON.parse(localStorage.getItem('theme-store') || 'null');
            document.documentElement.dataset.theme = stored?.state?.theme || 'cyberpunk';
          } catch {}
        };
        applyTheme();
        document.documentElement.classList.remove('no-js');
        // View Transitions reset <html> attributes to the server-rendered default
        // on each swap, so re-apply the saved theme after every navigation.
        // Registered once here; the document (and this listener) persist across swaps.
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>

    <ClientRouter />
  </head>

  <body>
    <!-- Ambient grid + scanline backdrop -->
    {
      backdrop && (
        <div class="pointer-events-none fixed inset-0 -z-10 bg-grid" aria-hidden="true" />
      )
    }

    {FEATURES.introLoader && <IntroLoader />}
    {FEATURES.customCursor && <Cursor client:load />}

    <Header />

    <main id="main" class="mx-auto w-full max-w-6xl px-5">
      <slot />
    </main>

    <Footer />

    <ScrollReveal />
  </body>
</html>
