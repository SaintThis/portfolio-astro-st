---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import Reveal from '@components/ui/Reveal.astro';
import Tag from '@components/ui/Tag.astro';
import { BLOG } from '@/config';
import { getPosts } from '@lib/api';
import { formatDate, isoDate } from '@lib/utils';

// On-demand rendered: reads posts live from the DB (falls back to Content
// Collections when DATABASE_URL is unset). Draft filtering happens in the repo.
// Category filter + pagination are driven by ?category= and ?page= query params
// (server-side, zero client JS) since this route already renders per request.
export const prerender = false;

const all = await getPosts();

// Category chips: only those that actually have posts, with counts.
const counts = new Map<string, number>();
for (const p of all) if (p.category) counts.set(p.category, (counts.get(p.category) ?? 0) + 1);
const labelFor = (slug: string) =>
  BLOG.categories.find((c) => c.slug === slug)?.label ?? slug;
const categories = [...counts.keys()].sort((a, b) => labelFor(a).localeCompare(labelFor(b)));

const params = Astro.url.searchParams;
const activeCategory = params.get('category');
const filtered = activeCategory ? all.filter((p) => p.category === activeCategory) : all;

const pageSize = BLOG.pageSize;
const totalPages = Math.max(1, Math.ceil(filtered.length / pageSize));
const page = Math.min(totalPages, Math.max(1, Number(params.get('page')) || 1));
const posts = filtered.slice((page - 1) * pageSize, page * pageSize);

// Build a query string preserving category while changing page.
const hrefFor = (opts: { category?: string | null; page?: number }) => {
  const sp = new URLSearchParams();
  const cat = opts.category === undefined ? activeCategory : opts.category;
  if (cat) sp.set('category', cat);
  if (opts.page && opts.page > 1) sp.set('page', String(opts.page));
  const qs = sp.toString();
  return qs ? `/blog?${qs}` : '/blog';
};
---

<BaseLayout
  title="Blog"
  description="Notes on fullstack development — architecture, Rust, frontend performance, and lessons from production."
>
  <section class="py-16">
    <SectionHeading kicker="./blog" title="Writing" index="//" />
    <p class="mt-4 max-w-xl text-fg-muted">
      Field notes on architecture, Rust, and shipping maintainable software.
    </p>

    {
      categories.length > 0 && (
        <div class="mt-8 flex flex-wrap gap-2" aria-label="Filter by category">
          <a
            href={hrefFor({ category: null, page: 1 })}
            class:list={['cat-chip', !activeCategory && 'is-active']}
            data-cursor="hover"
          >
            all <span class="cat-chip__count">{all.length}</span>
          </a>
          {categories.map((c) => (
            <a
              href={hrefFor({ category: c, page: 1 })}
              class:list={['cat-chip', activeCategory === c && 'is-active']}
              data-cursor="hover"
            >
              {labelFor(c)} <span class="cat-chip__count">{counts.get(c)}</span>
            </a>
          ))}
        </div>
      )
    }

    <ul class="mt-10 divide-y divide-border">
      {
        posts.map((post, i) => (
          <li>
            <Reveal delay={(i % 4) * 0.05}>
              <a
                href={`/blog/${post.slug}`}
                data-cursor="hover"
                data-cursor-label="Read"
                class="group grid gap-2 py-6 transition-colors sm:grid-cols-[8rem_1fr] sm:gap-6"
              >
                <time datetime={isoDate(post.date)} class="font-mono text-xs text-fg-faint sm:pt-1">
                  {formatDate(post.date)}
                </time>
                <div>
                  <div class="flex flex-wrap items-center gap-2">
                    {post.category && (
                      <span class="font-mono text-[0.65rem] uppercase tracking-wider text-accent-2">
                        {labelFor(post.category)}
                      </span>
                    )}
                    <h2 class="text-xl font-bold transition-colors group-hover:text-accent">
                      {post.title}
                    </h2>
                  </div>
                  <p class="mt-1 text-sm text-fg-muted">{post.description}</p>
                  <div class="mt-3 flex flex-wrap gap-1.5">
                    {post.tags.map((t) => (
                      <Tag>{t}</Tag>
                    ))}
                  </div>
                </div>
              </a>
            </Reveal>
          </li>
        ))
      }
    </ul>

    {
      filtered.length === 0 && (
        <p class="mt-10 font-mono text-fg-faint">// no posts here yet — soon™</p>
      )
    }

    {
      totalPages > 1 && (
        <nav class="mt-12 flex items-center justify-between font-mono text-sm" aria-label="Pagination">
          {page > 1 ? (
            <a href={hrefFor({ page: page - 1 })} class="page-link" data-cursor="hover">
              ← newer
            </a>
          ) : (
            <span class="page-link is-disabled">← newer</span>
          )}
          <span class="text-fg-faint">
            page {page} / {totalPages}
          </span>
          {page < totalPages ? (
            <a href={hrefFor({ page: page + 1 })} class="page-link" data-cursor="hover">
              older →
            </a>
          ) : (
            <span class="page-link is-disabled">older →</span>
          )}
        </nav>
      )
    }
  </section>
</BaseLayout>

<style>
  .cat-chip {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.35rem 0.8rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-box);
    color: var(--color-fg-muted);
    transition: color 0.2s var(--ease-out-expo), border-color 0.2s var(--ease-out-expo);
  }
  .cat-chip:hover {
    color: var(--color-fg);
    border-color: var(--color-accent);
  }
  .cat-chip.is-active {
    background: var(--color-accent);
    color: var(--color-accent-contrast);
    border-color: var(--color-accent);
  }
  .cat-chip__count {
    opacity: 0.6;
    font-size: 0.7rem;
  }
  .page-link {
    color: var(--color-fg-muted);
    transition: color 0.2s var(--ease-out-expo);
  }
  .page-link:hover {
    color: var(--color-accent);
  }
  .page-link.is-disabled {
    opacity: 0.35;
  }
</style>
