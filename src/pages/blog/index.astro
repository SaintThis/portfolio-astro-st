---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import Reveal from '@components/ui/Reveal.astro';
import Tag from '@components/ui/Tag.astro';
import { formatDate, isoDate } from '@lib/utils';

const posts = (await getCollection('blog', ({ data }) => import.meta.env.PROD ? !data.draft : true))
  .sort((a, b) => +b.data.date - +a.data.date);
---

<BaseLayout
  title="Blog"
  description="Notes on fullstack development — architecture, Rust, frontend performance, and lessons from production."
>
  <section class="py-16">
    <SectionHeading kicker="./blog" title="Writing" index="//" />
    <p class="mt-4 max-w-xl text-fg-muted">
      Field notes on architecture, Rust, and shipping maintainable software.
    </p>

    <ul class="mt-10 divide-y divide-border">
      {
        posts.map((post, i) => (
          <li>
            <Reveal delay={(i % 4) * 0.05}>
              <a
                href={`/blog/${post.id}`}
                data-cursor="hover"
                data-cursor-label="Read"
                class="group grid gap-2 py-6 transition-colors sm:grid-cols-[8rem_1fr] sm:gap-6"
              >
                <time
                  datetime={isoDate(post.data.date)}
                  class="font-mono text-xs text-fg-faint sm:pt-1"
                >
                  {formatDate(post.data.date)}
                </time>
                <div>
                  <h2 class="text-xl font-bold transition-colors group-hover:text-accent">
                    {post.data.title}
                  </h2>
                  <p class="mt-1 text-sm text-fg-muted">{post.data.description}</p>
                  <div class="mt-3 flex flex-wrap gap-1.5">
                    {post.data.tags.map((t) => (
                      <Tag>{t}</Tag>
                    ))}
                  </div>
                </div>
              </a>
            </Reveal>
          </li>
        ))
      }
    </ul>

    {posts.length === 0 && <p class="mt-10 font-mono text-fg-faint">// no posts yet — soon™</p>}
  </section>
</BaseLayout>
