---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Tag from '@components/ui/Tag.astro';
import { formatDate, isoDate, readingTime } from '@lib/utils';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const mins = readingTime(post.body ?? '');

// Related posts: prefer shared tags, fall back to latest so the section is
// never empty — readers always leave with a next thing to read.
const otherPosts = (
  await getCollection('blog', ({ data, id }) =>
    id !== post.id && (import.meta.env.PROD ? !data.draft : true)
  )
).sort((a, b) => +b.data.date - +a.data.date);

const tagOverlap = (candidate: (typeof otherPosts)[number]) =>
  candidate.data.tags.filter((t) => post.data.tags.includes(t)).length;

const related = [...otherPosts]
  .sort((a, b) => tagOverlap(b) - tagOverlap(a) || +b.data.date - +a.data.date)
  .slice(0, 3);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  type="article"
  publishedTime={isoDate(post.data.date)}
  modifiedTime={post.data.updated ? isoDate(post.data.updated) : undefined}
  tags={post.data.tags}
>
  <article class="py-16">
    <a href="/blog" class="font-mono text-sm text-fg-muted hover:text-accent" data-cursor="hover"
      >← all posts</a
    >

    <header class="mt-6 max-w-3xl">
      <div class="flex flex-wrap items-center gap-3 font-mono text-xs text-fg-faint">
        <time datetime={isoDate(post.data.date)}>{formatDate(post.data.date)}</time>
        <span>·</span>
        <span>{mins} min read</span>
      </div>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight sm:text-5xl">{post.data.title}</h1>
      <p class="mt-4 text-lg text-fg-muted">{post.data.description}</p>
      <div class="mt-4 flex flex-wrap gap-1.5">
        {post.data.tags.map((t) => <Tag accent>{t}</Tag>)}
      </div>
    </header>

    <div class="prose-cyber mt-10 max-w-3xl">
      <Content />
    </div>

    {
      related.length > 0 && (
        <footer class="mt-20 max-w-3xl border-t border-border pt-10">
          <p class="kicker mb-6">
            <span class="text-accent-2">//</span> Read next
          </p>
          <ul class="space-y-5">
            {related.map((r) => (
              <li>
                <a
                  href={`/blog/${r.id}`}
                  data-cursor="hover"
                  data-cursor-label="Read"
                  class="group block"
                >
                  <div class="flex flex-wrap items-center gap-3 font-mono text-xs text-fg-faint">
                    <time datetime={isoDate(r.data.date)}>{formatDate(r.data.date)}</time>
                    {tagOverlap(r) > 0 && <span class="text-accent">related</span>}
                  </div>
                  <h3 class="mt-1 text-lg font-bold transition-colors group-hover:text-accent">
                    {r.data.title}
                  </h3>
                  <p class="mt-1 text-sm text-fg-muted">{r.data.description}</p>
                </a>
              </li>
            ))}
          </ul>
        </footer>
      )
    }
  </article>
</BaseLayout>

<style is:global>
  /* Article typography — scoped to .prose-cyber so it never leaks. */
  .prose-cyber {
    line-height: 1.8;
    color: var(--color-fg-muted);
  }
  .prose-cyber > * + * { margin-top: 1.25rem; }
  .prose-cyber h2 {
    margin-top: 2.5rem;
    font-size: 1.6rem;
    color: var(--color-fg);
    scroll-margin-top: 6rem;
  }
  .prose-cyber h2::before { content: '# '; color: var(--color-accent-2); }
  .prose-cyber h3 { margin-top: 2rem; font-size: 1.25rem; color: var(--color-fg); }
  .prose-cyber a { color: var(--color-accent); text-decoration: underline; text-underline-offset: 3px; }
  .prose-cyber strong { color: var(--color-fg); }
  .prose-cyber ul, .prose-cyber ol { padding-left: 1.4rem; }
  .prose-cyber ul { list-style: none; }
  .prose-cyber ul li::before { content: '▹ '; color: var(--color-accent); margin-left: -1.2rem; }
  .prose-cyber ol { list-style: decimal; }
  .prose-cyber blockquote {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    color: var(--color-fg);
    font-style: italic;
  }
  .prose-cyber code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-surface-2);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    color: var(--color-accent-2);
  }
  .prose-cyber pre {
    background: var(--color-surface) !important;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-box);
    padding: 1.25rem;
    overflow-x: auto;
  }
  .prose-cyber pre code { background: none; padding: 0; color: inherit; }
</style>
