---
import BaseLayout from '@layouts/BaseLayout.astro';
import Tag from '@components/ui/Tag.astro';
import ReadingProgress from '@components/blog/ReadingProgress.astro';
import TableOfContents from '@components/blog/TableOfContents.astro';
import ShareRail from '@components/blog/ShareRail.astro';
import PostAside from '@components/blog/PostAside.astro';
import PostHeroMedia from '@components/blog/PostHeroMedia.astro';
import ViewTracker from '@components/blog/ViewTracker.astro';
import { BLOG } from '@/config';
import { getPost, getPosts } from '@lib/api';
import { formatDate, isoDate } from '@lib/utils';

// On-demand rendered: reads the post live from the DB at request time.
export const prerender = false;

const { slug } = Astro.params;
const post = await getPost(slug!);
if (!post) return Astro.redirect('/404');

const mins = post.readingTime;
const path = `/blog/${post.slug}`;
const headings = post.headings ?? [];

// Related posts: prefer shared tags, fall back to latest so the section is
// never empty — readers always leave with a next thing to read.
const otherPosts = (await getPosts()).filter((p) => p.slug !== post.slug);

const tagOverlap = (candidate: (typeof otherPosts)[number]) =>
  candidate.tags.filter((t) => post.tags.includes(t)).length;

const related = [...otherPosts]
  .sort((a, b) => tagOverlap(b) - tagOverlap(a) || +new Date(b.date) - +new Date(a.date))
  .slice(0, 3);
---

<BaseLayout
  title={post.title}
  description={post.description}
  type="article"
  publishedTime={isoDate(post.date)}
  modifiedTime={post.updated ? isoDate(post.updated) : undefined}
  tags={post.tags}
  wide
>
  {BLOG.readingProgress && <ReadingProgress target="#post-body" />}
  {BLOG.viewCounts && <ViewTracker slug={post.slug} />}

  <div class="py-16">
    <a href="/blog" class="font-mono text-sm text-fg-muted hover:text-accent" data-cursor="hover"
      >← all posts</a
    >

    <!--
      Reading layout. Below `lg` everything stacks (article only, centered).
      At `lg` a three-track grid opens up: left aside (share + sponsor/newsletter),
      the article, and a sticky table of contents on the right.

      Generous gutters are deliberate — the rails must read as separate furniture,
      not as part of the article. Combined with BaseLayout's `wide` container this
      leaves the centre column ~44rem (a comfortable ~70ch measure) instead of the
      cramped ~40rem the rails would otherwise squeeze it to.
    -->
    <div
      class="mt-6 lg:grid lg:grid-cols-[12rem_minmax(0,1fr)_14rem] lg:items-start lg:gap-12 xl:gap-16"
    >
      <!-- Left aside — hidden until lg. -->
      {
        BLOG.leftAside && (
          <PostAside title={post.title} path={path} series={post.series} class="hidden lg:block" />
        )
      }

      <article class="min-w-0 max-w-3xl">
        <header>
          <div class="flex flex-wrap items-center gap-3 font-mono text-xs text-fg-faint">
            {post.category && <span class="text-accent-2">{post.category}</span>}
            <time datetime={isoDate(post.date)}>{formatDate(post.date)}</time>
            <span>·</span>
            <span>{mins} min read</span>
            {
              BLOG.viewCounts && (
                <>
                  <span>·</span>
                  <span>
                    <span data-view-count>{(post.views ?? 0).toLocaleString()}</span> views
                  </span>
                </>
              )
            }
          </div>
          <h1 class="mt-4 text-4xl font-extrabold leading-tight sm:text-5xl">{post.title}</h1>
          <p class="mt-4 text-lg text-fg-muted">{post.description}</p>
          <div class="mt-4 flex flex-wrap gap-1.5">
            {post.tags.map((t) => <Tag accent>{t}</Tag>)}
          </div>

          <PostHeroMedia heroVideo={post.heroVideo} cover={post.cover} alt={post.title} />

          <!-- Horizontal share row — always visible, including on mobile where
               the left aside is hidden. -->
          {
            BLOG.shareRail && (
              <div class="mt-6 border-y border-border py-3 lg:hidden">
                <ShareRail title={post.title} path={path} />
              </div>
            )
          }
        </header>

        <div id="post-body" class="prose-cyber mt-10" set:html={post.bodyHtml}></div>

        {
          related.length > 0 && (
            <footer class="mt-20 border-t border-border pt-10">
              <p class="kicker mb-6">
                <span class="text-accent-2">//</span> Read next
              </p>
              <ul class="space-y-5">
                {related.map((r) => (
                  <li>
                    <a
                      href={`/blog/${r.slug}`}
                      data-cursor="hover"
                      data-cursor-label="Read"
                      class="group block"
                    >
                      <div class="flex flex-wrap items-center gap-3 font-mono text-xs text-fg-faint">
                        <time datetime={isoDate(r.date)}>{formatDate(r.date)}</time>
                        {tagOverlap(r) > 0 && <span class="text-accent">related</span>}
                      </div>
                      <h3 class="mt-1 text-lg font-bold transition-colors group-hover:text-accent">
                        {r.title}
                      </h3>
                      <p class="mt-1 text-sm text-fg-muted">{r.description}</p>
                    </a>
                  </li>
                ))}
              </ul>
            </footer>
          )
        }
      </article>

      <!-- Right table of contents — hidden until lg. -->
      {
        BLOG.tableOfContents && <TableOfContents headings={headings} class="hidden lg:block" />
      }
    </div>
  </div>
</BaseLayout>

<style is:global>
  /* Article typography — scoped to .prose-cyber so it never leaks. */
  .prose-cyber {
    line-height: 1.8;
    color: var(--color-fg-muted);
  }
  .prose-cyber > * + * { margin-top: 1.25rem; }
  .prose-cyber h2 {
    margin-top: 2.5rem;
    font-size: 1.6rem;
    color: var(--color-fg);
    scroll-margin-top: 6rem;
  }
  .prose-cyber h2::before { content: '# '; color: var(--color-accent-2); }
  .prose-cyber h3 {
    margin-top: 2rem;
    font-size: 1.25rem;
    color: var(--color-fg);
    scroll-margin-top: 6rem;
  }
  .prose-cyber a { color: var(--color-accent); text-decoration: underline; text-underline-offset: 3px; }
  .prose-cyber strong { color: var(--color-fg); }
  .prose-cyber ul, .prose-cyber ol { padding-left: 1.4rem; }
  .prose-cyber ul { list-style: none; }
  .prose-cyber ul li::before { content: '▹ '; color: var(--color-accent); margin-left: -1.2rem; }
  .prose-cyber ol { list-style: decimal; }
  .prose-cyber blockquote {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    color: var(--color-fg);
    font-style: italic;
  }
  .prose-cyber code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-surface-2);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    color: var(--color-accent-2);
  }
  .prose-cyber pre {
    background: var(--color-surface) !important;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-box);
    padding: 1.25rem;
    overflow-x: auto;
  }
  .prose-cyber pre code { background: none; padding: 0; color: inherit; }
  /* Inline video/iframe embeds inside the article body. */
  .prose-cyber iframe, .prose-cyber video {
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-box);
  }
</style>
