---
/**
 * Centralized <head> SEO. One place for title/description/OG/Twitter/canonical
 * + JSON-LD. Every page passes its own values; sensible defaults come from config.
 */
import { SITE, AUTHOR, SOCIALS } from '@/config';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  /** 'website' | 'article' — drives OG type + article JSON-LD. */
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
  noindex?: boolean;
}

const {
  title,
  description = SITE.description,
  image = SITE.ogImage,
  type = 'website',
  publishedTime,
  modifiedTime,
  tags = [],
  noindex = false,
} = Astro.props;

const pageTitle = title ? `${title} — ${SITE.name}` : SITE.title;
const canonical = new URL(Astro.url.pathname, SITE.url).href;
const ogImage = new URL(image, SITE.url).href;

// Structured data: Person on the home/about, Article on posts.
const jsonLd =
  type === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: title,
        description,
        image: ogImage,
        datePublished: publishedTime,
        dateModified: modifiedTime ?? publishedTime,
        author: { '@type': 'Person', name: AUTHOR.name, url: SITE.url },
        keywords: tags.join(', '),
        mainEntityOfPage: canonical,
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: AUTHOR.name,
        jobTitle: SITE.role,
        email: SITE.email,
        address: SITE.location,
        url: SITE.url,
        description: SITE.description,
        // Links Google's Knowledge Graph entry for this name to the same
        // identity across profiles — the single highest-leverage addition
        // to a Person schema beyond the basics.
        sameAs: SOCIALS.filter((s) => s.href.startsWith('http')).map((s) => s.href),
      };
---

<!-- Primary -->
<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
<meta name="author" content={AUTHOR.name} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:locale" content={SITE.locale.replace('-', '_')} />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
{tags.map((t) => <meta property="article:tag" content={t} />)}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
