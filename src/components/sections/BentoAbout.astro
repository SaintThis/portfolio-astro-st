---
/** Bento grid — a compact "about me" mosaic for the home page. */
import { SITE } from '@/config';
import Reveal from '@components/ui/Reveal.astro';
import Tag from '@components/ui/Tag.astro';

const cell =
  'rounded-[var(--radius-box)] border border-border bg-surface p-5 transition-colors hover:border-accent/40';
---

<section class="py-20">
  <Reveal>
    <div class="grid auto-rows-[minmax(120px,auto)] grid-cols-2 gap-3 md:grid-cols-4">
      <!-- Big intro cell -->
      <div class={`${cell} col-span-2 row-span-2 flex flex-col justify-between md:col-span-2`}>
        <span class="kicker">// whoami</span>
        <p class="mt-4 text-lg leading-relaxed text-fg">
          Fullstack developer who cares about the <span class="text-accent">last 10%</span> —
          performance, DX, and code the next dev can actually read.
        </p>
        <div class="mt-4 flex flex-wrap gap-1.5">
          <Tag accent>SOLID</Tag><Tag accent>Clean Code</Tag><Tag accent>MFE</Tag>
        </div>
      </div>

      <!-- Stat: experience -->
      <div class={`${cell} flex flex-col justify-center`}>
        <div class="font-mono text-4xl font-bold text-gradient">2+</div>
        <div class="mt-1 text-xs text-fg-muted">years shipping production apps</div>
      </div>

      <!-- Stat: tech debt -->
      <div class={`${cell} flex flex-col justify-center`}>
        <div class="font-mono text-4xl font-bold text-gradient">25%</div>
        <div class="mt-1 text-xs text-fg-muted">tech debt cut via agent workflow</div>
      </div>

      <!-- Location / timezone -->
      <div class={`${cell} col-span-2 flex items-center gap-3 md:col-span-1`}>
        <span class="text-2xl">📍</span>
        <div>
          <div class="text-sm font-semibold">{SITE.location}</div>
          <div class="font-mono text-[11px] text-fg-faint">UTC+8 · remote-friendly</div>
        </div>
      </div>

      <!-- Now playing / current -->
      <div class={`${cell} col-span-2 md:col-span-3`}>
        <span class="kicker">// currently</span>
        <p class="mt-2 text-sm text-fg-muted">
          UI/UX on an enterprise <span class="text-fg">Quality Cockpit</span> system with a Japanese
          client team — GitLab MR workflows across five subsystems.
        </p>
      </div>
    </div>
  </Reveal>
</section>
