---
/**
 * Polymorphic button/link. Renders <a> when `href` is set, else <button>.
 * Variants map to the accent system; all are theme-reactive.
 */
import { cn } from '@lib/utils';

interface Props {
  href?: string;
  variant?: 'primary' | 'ghost' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  type?: 'button' | 'submit';
  [key: string]: unknown;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className,
  type = 'button',
  ...rest
} = Astro.props;

const base =
  'group relative inline-flex items-center justify-center gap-2 rounded-[var(--radius-box)] font-mono font-medium tracking-wide transition-all duration-200 focus-visible:outline-none disabled:opacity-50';

const variants = {
  primary:
    'bg-accent text-accent-contrast hover:box-glow hover:-translate-y-0.5 active:translate-y-0',
  outline: 'border border-accent text-accent hover:bg-accent hover:text-accent-contrast',
  ghost: 'text-fg-muted hover:text-fg hover:bg-surface',
};

const sizes = {
  sm: 'px-3 py-1.5 text-xs',
  md: 'px-5 py-2.5 text-sm',
  lg: 'px-7 py-3.5 text-base',
};

const cls = cn(base, variants[variant], sizes[size], className);
const Tag = href ? 'a' : 'button';
---

<Tag
  class={cls}
  href={href}
  type={href ? undefined : type}
  data-cursor="hover"
  {...rest}
>
  <slot />
</Tag>
