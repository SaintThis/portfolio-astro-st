---
/** A faux terminal/editor chrome wrapper — the signature "coder" motif. */
interface Props {
  title?: string;
  class?: string;
}
const { title = 'zsh — saint@dev', class: className } = Astro.props;
---

<div
  class:list={[
    'overflow-hidden rounded-[var(--radius-box)] border border-border bg-surface',
    className,
  ]}
>
  <div class="flex items-center gap-2 border-b border-border bg-surface-2 px-4 py-2.5">
    <span class="h-3 w-3 rounded-full bg-danger/80"></span>
    <span class="h-3 w-3 rounded-full bg-warning/80"></span>
    <span class="h-3 w-3 rounded-full bg-success/80"></span>
    <span class="ml-3 font-mono text-xs text-fg-faint">{title}</span>
  </div>
  <div class="p-4 sm:p-6">
    <slot />
  </div>
</div>
