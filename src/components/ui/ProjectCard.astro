---
import type { Project } from '@lib/api/types';
import Tag from '@components/ui/Tag.astro';
import { formatDate } from '@lib/utils';

interface Props {
  project: Project;
}
const { project } = Astro.props;
const href = project.links.caseStudy ?? `/projects/${project.slug}`;

const statusMap = {
  live: { label: 'LIVE', color: 'text-success' },
  wip: { label: 'WIP', color: 'text-warning' },
  archived: { label: 'ARCHIVED', color: 'text-fg-faint' },
};
const status = statusMap[project.status];
---

<a
  href={href}
  data-cursor="hover"
  data-cursor-label="View"
  class="group relative flex h-full flex-col overflow-hidden rounded-[var(--radius-box)] border border-border bg-surface p-4 transition-all duration-300 hover:border-accent/60 hover:box-glow sm:p-5"
>
  <!-- accent corner bracket -->
  <span
    class="absolute right-0 top-0 h-6 w-6 border-r-2 border-t-2 border-accent/0 transition-colors duration-300 group-hover:border-accent"
  ></span>

  <div class="mb-3 flex items-center justify-between">
    <span class="font-mono text-[11px] tracking-widest text-fg-faint">
      {project.category.toUpperCase()}
    </span>
    <span class:list={['font-mono text-[11px] tracking-widest', status.color]}>
      ● {status.label}
    </span>
  </div>

  <h3 class="text-lg font-bold transition-colors group-hover:text-accent sm:text-xl">
    {project.title}
  </h3>
  <p class="mt-2 text-sm text-fg-muted">{project.summary}</p>

  {
    project.metrics && (
      <div class="mt-4 flex gap-4 sm:gap-5">
        {project.metrics.map((m) => (
          <div>
            <div class="font-mono text-base font-bold text-accent-2 sm:text-lg">{m.value}</div>
            <div class="text-[11px] text-fg-faint">{m.label}</div>
          </div>
        ))}
      </div>
    )
  }

  <div class="mt-4 flex flex-wrap gap-1.5">
    {project.tags.slice(0, 4).map((t) => <Tag>{t}</Tag>)}
  </div>

  <div
    class="mt-auto flex items-center justify-between border-t border-border pt-3 font-mono text-[11px] text-fg-faint"
  >
    <span>{formatDate(project.date, { year: 'numeric', month: 'short' })}</span>
    <span class="text-accent-2 transition-transform group-hover:translate-x-1">→</span>
  </div>
</a>
