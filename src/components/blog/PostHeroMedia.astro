---
/**
 * PostHeroMedia — the introduction visual above a post body. Prefers a hero
 * video when `heroVideo` is set, otherwise falls back to the `cover` image.
 * Renders nothing if neither is present.
 *
 * Video support: YouTube / Vimeo URLs become privacy-friendly lazy iframes;
 * a direct .mp4/.webm URL becomes a native <video>. This is the same path the
 * article body can use for inline videos — see the note in the post page.
 */
interface Props {
  heroVideo?: string;
  /** Image URL/path (from the DB or frontmatter). */
  cover?: string;
  alt: string;
}
const { heroVideo, cover, alt } = Astro.props;

/** Return an embeddable iframe src, or null for non-embeddable (raw file) URLs. */
function toEmbed(url: string): string | null {
  const yt = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([\w-]{11})/);
  if (yt) return `https://www.youtube-nocookie.com/embed/${yt[1]}`;
  const vimeo = url.match(/vimeo\.com\/(\d+)/);
  if (vimeo) return `https://player.vimeo.com/video/${vimeo[1]}`;
  return null;
}

const isFile = heroVideo ? /\.(mp4|webm|ogg)$/i.test(heroVideo) : false;
const embed = heroVideo && !isFile ? toEmbed(heroVideo) : null;
---

{
  (heroVideo || cover) && (
    <figure class="post-hero">
      {isFile && heroVideo ? (
        <video
          class="post-hero__media"
          src={heroVideo}
          controls
          preload="metadata"
          playsinline
          aria-label={alt}
        />
      ) : embed ? (
        <div class="post-hero__frame">
          <iframe
            class="post-hero__media"
            src={embed}
            title={alt}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          />
        </div>
      ) : cover ? (
        <img src={cover} alt={alt} class="post-hero__media" loading="eager" decoding="async" />
      ) : null}
    </figure>
  )
}

<style>
  .post-hero {
    margin-top: 2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-box);
    overflow: hidden;
    background: var(--color-surface);
  }
  .post-hero__frame {
    position: relative;
    padding-top: 56.25%; /* 16:9 */
  }
  .post-hero__frame .post-hero__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .post-hero__media {
    display: block;
    width: 100%;
    height: auto;
  }
  video.post-hero__media {
    max-height: 70vh;
  }
</style>
