---
/**
 * ReadingProgress — a thin linear bar pinned to the top of the viewport that
 * fills as the reader scrolls through the article body. Zero-JS by default
 * (renders empty), progressively enhanced by the inline script below.
 *
 * Scroll-linked, so it's inherently correct under `prefers-reduced-motion`
 * (there's no easing to disable — the fill tracks scroll 1:1). Re-inits on
 * `astro:page-load` for View Transitions and guards against double-binding.
 */
interface Props {
  /** CSS selector for the element whose scroll range drives the bar. */
  target?: string;
  class?: string;
}
const { target = 'article', class: className = '' } = Astro.props;
---

<div
  class:list={['reading-progress', className]}
  data-progress-target={target}
  role="progressbar"
  aria-label="Article reading progress"
  aria-valuemin="0"
  aria-valuemax="100"
  aria-valuenow="0"
>
  <span class="reading-progress__fill" aria-hidden="true"></span>
</div>

<style>
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    z-index: 60;
    background: transparent;
    pointer-events: none;
  }
  .reading-progress__fill {
    display: block;
    height: 100%;
    width: 100%;
    transform: scaleX(0);
    transform-origin: 0 50%;
    background: linear-gradient(90deg, var(--color-accent), var(--color-accent-2));
    box-shadow: var(--glow) var(--color-accent);
  }
</style>

<script>
  function initReadingProgress() {
    const bars = document.querySelectorAll<HTMLElement>('.reading-progress');
    bars.forEach((bar) => {
      if (bar.dataset.bound) return;
      bar.dataset.bound = 'true';

      const fill = bar.querySelector<HTMLElement>('.reading-progress__fill');
      const target = document.querySelector<HTMLElement>(
        bar.dataset.progressTarget || 'article'
      );
      if (!fill || !target) return;

      let ticking = false;
      const update = () => {
        ticking = false;
        const start = target.offsetTop;
        const end = start + target.offsetHeight - window.innerHeight;
        const range = Math.max(1, end - start);
        const ratio = Math.min(1, Math.max(0, (window.scrollY - start) / range));
        fill.style.transform = `scaleX(${ratio})`;
        bar.setAttribute('aria-valuenow', String(Math.round(ratio * 100)));
      };
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(update);
      };

      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
      update();
    });
  }

  document.addEventListener('astro:page-load', initReadingProgress);
</script>
